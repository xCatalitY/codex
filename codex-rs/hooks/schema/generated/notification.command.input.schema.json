{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "NullableString": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "properties": {
    "agent": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "agent_type": {
      "type": "string"
    },
    "cell_id": {
      "type": "string"
    },
    "child": {
      "type": "string"
    },
    "child_index": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "child_run_id": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "data": true,
    "error": {
      "type": "string"
    },
    "event": {
      "type": "string"
    },
    "hook_event_name": {
      "const": "Notification",
      "type": "string"
    },
    "item_index": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "message": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "notification_type": {
