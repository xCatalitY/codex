      "type": "string"
    },
    "permission_mode": {
      "enum": [
        "default",
        "acceptEdits",
        "plan",
        "dontAsk",
        "bypassPermissions"
      ],
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "stage_index": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "step_index": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "transcript_path": {
      "$ref": "#/definitions/NullableString"
    },
