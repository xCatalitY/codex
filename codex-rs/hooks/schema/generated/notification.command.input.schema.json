      "description": "Codex extension: expose the active turn id to internal turn-scoped hooks.",
      "type": "string"
    },
    "unix_ms": {
      "format": "int64",
      "type": "integer"
    },
    "workflow": {
      "type": "string"
    },
    "workflow_agent_id": {
      "type": "string"
    }
